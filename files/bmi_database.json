    "bmr_calculation": {
      "female_formula": "655 + (9.6 × weight_kg) + (1.8 × height_cm) - (4.7 × age_years)",
      "male_formula": "66 + (13.7 × weight_kg) + (5 × height_cm) - (6.8 × age_years)",
      
